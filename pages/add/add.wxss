/* 类型切换 */
.type-switch {
  display: flex;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 8rpx;
  margin: 20rpx;
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #999;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.type-item.active {
  background: white;
  color: #4A90E2;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 金额输入 */
.amount-section {
  background: white;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  margin: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.currency {
  font-size: 60rpx;
  font-weight: bold;
  color: #4A90E2;
}

.amount-input {
  flex: 1;
  font-size: 80rpx;
  font-weight: bold;
  color: #333;
}

.amount-input::placeholder {
  color: #E0E0E0;
}

/* 类别选择 */
.category-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.category-item.active {
  background: #F0F5FF;
}

.category-icon {
  font-size: 48rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

.category-item.active .category-name {
  color: #4A90E2;
}

/* 备注输入 */
.remark-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
}

.remark-input {
  font-size: 28rpx;
  color: #333;
  padding: 20rpx 0;
}

.remark-input::placeholder {
  color: #CCC;
}

/* 日期选择 */
.date-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
}

.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #333;
  padding: 20rpx 0;
}

.date-picker .arrow {
  color: #CCC;
  font-size: 40rpx;
}

/* 按钮组 */
.btn-group {
  padding: 40rpx 20rpx;
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  color: white;
}

.btn-danger {
  background: #FF5252;
  color: white;
  max-width: 200rpx;
}
